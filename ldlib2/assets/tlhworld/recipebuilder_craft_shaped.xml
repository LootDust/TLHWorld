            <element style='flex-direction:row'>
              <item-slot id='item3'/>
              <item-slot id='item4'/>
              <item-slot id='item5'/>
            </element>
            <element style='flex-direction:row'>
              <item-slot id='item6'/>
              <item-slot id='item7'/>
              <item-slot id='item8'/>
            </element>
          </element>
          <button id='confirmBtn' style='height:17; width:24; top:18; left:6; background: sprite(tlhisland:textures/gui/progress_arrow_empty.png)'/>
          <item-slot id='item9' style='top:18; left:16; background: sprite(tlhisland:textures/gui/crafting_output.png) scale(1.44);'/>
